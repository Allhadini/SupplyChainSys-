# ─────────────────────────────────────────────
# Atlas-Logix — Environment Configuration
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/atlas_logix

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKER=localhost:9092

# JWT
JWT_SECRET=supersecret
JWT_EXPIRES_IN=7d

# External AI / Optimization Services (Python FastAPI)
AI_SERVICE_URL=http://localhost:8000
OPTIMIZATION_SERVICE_URL=http://localhost:9000

# Risk Threshold (triggers optimization + alerts)
RISK_THRESHOLD=0.7
